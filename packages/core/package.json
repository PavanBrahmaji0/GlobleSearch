{
  "name": "@globlesearch/core",
  "version": "0.1.0",
  "description": "Interactive 3D globe with smooth 2D map transition",
  "main": "./dist/globlesearch-core.umd.js",
  "module": "./dist/globlesearch-core.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/globlesearch-core.mjs",
      "require": "./dist/globlesearch-core.umd.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "cesium": "^1.120.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.0",
    "cesium": "^1.120.0",
    "leaflet": "^1.9.4",
    "typescript": "^5.4.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "leaflet": "^1.9.4"
  }
}
