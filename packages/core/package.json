{
  "name": "@globlesearch/core",
  "version": "0.1.0",
  "description": "Interactive 3D globe with spiral flight and globe-to-map morph, powered by CesiumJS",
  "keywords": ["globe", "3d", "cesium", "map", "interactive", "gis", "visualization"],
  "author": "PavanBrahmaji0",
  "license": "MIT",
  "homepage": "https://github.com/PavanBrahmaji0/GlobleSearch#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/PavanBrahmaji0/GlobleSearch.git"
  },
  "bugs": {
    "url": "https://github.com/PavanBrahmaji0/GlobleSearch/issues"
  },
  "main": "./dist/globlesearch-core.umd.js",
  "module": "./dist/globlesearch-core.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/globlesearch-core.mjs",
      "require": "./dist/globlesearch-core.umd.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build && tsc --project tsconfig.build.json",
    "test": "vitest run"
  },
  "peerDependencies": {
    "cesium": ">=1.100.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.0",
    "cesium": "^1.141.0",
    "typescript": "^5.4.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  }
}
